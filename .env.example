# Supabase
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key_aqui

# Opcional — sobrescreve os valores padrão
VITE_APP_URL=https://aloclinica.com.br

# Sentry (opcional)
VITE_SENTRY_DSN=sua_dsn_aqui

# Mercado Pago — chave PÚBLICA (client). NUNCA o access token aqui.
# Pega em: https://www.mercadopago.com.br/developers/panel/credentials
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-PUBLIC-KEY-PUBLICA-AQUI

# VAPID public key (Web Push). A private fica no Supabase Secrets.
VITE_VAPID_PUBLIC_KEY=

# MiroTalk / WhatsApp gateway / CompreFace (URLs públicas)
VITE_MIROTALK_URL=https://meet.telemedicinaaloclinica.sbs
VITE_WHATSAPP_GATEWAY_URL=https://whatsapp.telemedicinaaloclinica.sbs
VITE_COMPREFACE_URL=https://face.aloclinica.com.br

# =============================================================
# SUPABASE EDGE FUNCTION SECRETS (configurar via `supabase secrets set`,
# NUNCA no client/bundle). Adicionados pelo hardening de segurança:
# =============================================================
# Bootstrap do admin (função create-admin-account). Sem isto a função recusa.
#   ADMIN_BOOTSTRAP_SECRET=<segredo-forte-aleatorio>
#   ADMIN_BOOTSTRAP_EMAIL=<email-do-admin>
#   ADMIN_BOOTSTRAP_PASSWORD=<senha-forte>
# Segredo interno p/ funções chamadas por triggers SQL (process-refund,
# ai-ticket-triage, auto-clinical-summary, suggest-reschedule). DEVE ser igual
# ao app.settings.internal_function_secret no banco:
#   supabase secrets set INTERNAL_FUNCTION_SECRET=<segredo-forte-aleatorio>
#   ALTER DATABASE postgres SET app.settings.internal_function_secret = '<mesmo>';
# Webhooks — OBRIGATÓRIOS (fail closed sem eles).
#   MERCADOPAGO_WEBHOOK_SECRET=<secret-do-painel-MP>
#   DOCUSEAL_WEBHOOK_SECRET=<secret-compartilhado-docuseal>
# coturn (turn-credentials) — sem fallback hardcoded.
#   COTURN_PASS=<senha-coturn>
# Seed de teste — NUNCA habilitar em produção.
#   ALLOW_TEST_SEED=false
#   SEED_SECRET=<segredo-forte-aleatorio>
